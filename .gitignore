# ── Dependencies ─────────────────────────────────────────────────────
/node_modules
.pnpm-store/

# ── Next.js build output ─────────────────────────────────────────────
/.next
/.next-build-check
/out

# Next.js writes this with a different routes-types import path
# depending on whether `next dev` (./.next/dev/types/…) or `next build`
# / `next typegen` (./.next/types/…) most recently touched it, which
# produced churn in git status on every dev/prod switch. Treat it as
# build output; the `pretypecheck` script in package.json regenerates
# it via `next typegen` before `tsc` runs.
/next-env.d.ts

# ── TypeScript build cache ───────────────────────────────────────────
# `tsc --incremental` writes these; they're per-machine and noisy in
# diffs. Excluded everywhere, including the root and any subproject.
*.tsbuildinfo

# ── Test / coverage artifacts ────────────────────────────────────────
# Playwright stores screenshots, traces, videos, HTML reports, and
# throwaway SQLite data here during E2E runs. Keep the actual `e2e/`
# specs tracked, but never commit run output.
/test-results/
/playwright-report/
/blob-report/
/.playwright-data/

# Node/V8 coverage output from `npm run test:coverage`.
/coverage/
*.lcov

# Rust build output from `npm run test:tauri`.
/src-tauri/target/

# ── Local runtime data ───────────────────────────────────────────────
# /data is the SQLite location for `npm run dev` / Docker bind-mount.
# Treat it like a user database — never commit.
/data

# ── Cowork / sandbox session metadata ────────────────────────────────
# Most of `.claude/` is per-developer scratch state (resume session blob,
# settings.local.json, plans, transcripts). A few subdirectories are
# checked in so the protocol travels with the repo:
#   - .claude/commands/  → shared slash commands (e.g. /resume)
#   - .claude/agents/    → shared sub-agent definitions (if any)
# See CLAUDE.md → "Session continuity protocol" for details.
/sessions
/.claude/*
!/.claude/commands/
!/.claude/agents/

# ── OS metadata ──────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────────────
# Block the most common per-machine workspace files but allow shared
# `.vscode/extensions.json` etc. by listing the noisy ones explicitly.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

# ── Environment / secrets ────────────────────────────────────────────
# .env files routinely contain API keys. The `*.local` variants are the
# Next.js convention for per-developer overrides.
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ── Logs ─────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Smoke / scratch ──────────────────────────────────────────────────
__smoketest.ts
/tools/__pycache__
