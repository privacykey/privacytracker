# Published app image to run. Pin to a release tag for repeatable deployments.
PRIVACYTRACKER_IMAGE=ghcr.io/privacykey/privacytracker:latest

# Host header Traefik should route. Add this name to LAN DNS or /etc/hosts.
PRIVACYTRACKER_HOST=privacytracker.localhost

# Optional: setting this requires X-Auditor-Admin-Token on destructive API calls.
# The browser UI does not prompt for the token, so leave blank for normal LAN UI use.
AUDITOR_ADMIN_TOKEN=
