# Published app image to run. Pin to a release tag for repeatable deployments.
PRIVACYTRACKER_IMAGE=ghcr.io/privacykey/privacytracker:latest

# Hostname Caddy should serve. Use a LAN DNS name, mDNS name, or a real domain.
PRIVACYTRACKER_HOST=privacytracker.localhost

# Required for LAN/domain deployments. Set a long random value, then unlock
# admin actions in Settings with the same token. Local .localhost-only testing
# can leave this blank.
AUDITOR_ADMIN_TOKEN=
